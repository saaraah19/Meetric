# ─── Required ──────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Required to use /leads/export ─────────────────────────────────
# Any long random string. Example: openssl rand -hex 32
EXPORT_TOKEN=

# ─── Optional — restrict CORS ──────────────────────────────────────
# Comma-separated list of allowed origins, e.g.:
#   ALLOWED_ORIGINS=https://client-site.com,https://www.client-site.com
# Leave unset (or "*") to allow embedding on any site — the right
# default for a general-purpose embeddable widget. Lock this down once
# you know the exact domain(s) it'll be deployed on.
ALLOWED_ORIGINS=*

# ─── Optional — Slack alerts for hot leads ─────────────────────────
# Slack > Apps > Incoming Webhooks
SLACK_WEBHOOK_URL=

# ─── Optional — Notion CRM logging ─────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ─── Optional — logging verbosity ──────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR. Defaults to INFO.
LOG_LEVEL=INFO

# ─── Google Calendar (Agenda) Credentials ─────────────────────────────────
GOOGLE_CREDENTIALS_JSON=
GOOGLE_CALENDAR_ID=

# ─── Optional — business timezone for booking slots ────────────────
# Any valid IANA timezone name. Defaults to "Africa/Algiers" if unset.
# Examples: America/New_York, Europe/Paris, Asia/Dubai
BUSINESS_TIMEZONE=Africa/Algiers
